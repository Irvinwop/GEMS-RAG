+        for storage in (self.lightrag.text_chunks, self.lightrag.chunks_vdb):
+            records = await storage.get_by_ids(chunks)
+            if len(records) != len(chunks) or any(
+                record is None for record in records
+            ):
+                return False
+        return True
+
+    async def _reset_incomplete_text_stage(self, doc_id: str) -> None:
