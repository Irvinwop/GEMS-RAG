+def build_lightrag_global_config(lightrag: Any) -> Dict[str, Any]:
+    """Build the runtime config expected by the installed LightRAG version."""
+    builder = getattr(lightrag, "_build_global_config", None)
+    if callable(builder):
+        return builder()
+
+    config = asdict(lightrag)
+    role_llm_funcs = getattr(lightrag, "role_llm_funcs", None)
+    if role_llm_funcs is not None:
+        config["role_llm_funcs"] = dict(role_llm_funcs)
+    return config
+
