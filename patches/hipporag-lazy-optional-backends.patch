+    def _truncate_with_local_tokenizer(self, texts: List[str]):
+        max_tokens = self.global_config.embedding_max_seq_len
+        base_url = str(self.global_config.embedding_base_url or "").rstrip("/")
+        if not base_url or max_tokens <= 0:
+            return texts
+
+        if base_url.endswith("/v1"):
+            base_url = base_url[:-3]
+        tokenize_url = f"{base_url}/tokenize"
+        prepared = []
+        tokenizer_available = True
+        for text in texts:
+            if len(text.encode("utf-8")) < max_tokens or not tokenizer_available:
+                prepared.append(text)
+                continue
+
+            request = Request(
+                tokenize_url,
+                data=json.dumps({"content": text, "add_special": True}).encode("utf-8"),
+                headers={"Content-Type": "application/json"},
+            )
+            try:
+                with urlopen(request, timeout=30) as response:
+                    tokens = json.load(response)["tokens"]
+            except (OSError, TypeError, ValueError, KeyError):
+                tokenizer_available = False
+                prepared.append(text)
+                continue
+
+            if len(tokens) > max_tokens:
+                logger.warning(
+                    "Truncating embedding input from %d to %d tokens",
+                    len(tokens),
+                    max_tokens,
+                )
+                prepared.append(tokens[:max_tokens])
+            else:
+                prepared.append(text)
+        return prepared
+
