{
  "name": "mutcd150-rag-comparison",
  "dataset": {
    "qa_path": "external/MRAG_stp2/benchmarks/mutcd150/v1/mutcd_benchmark_questions_v1.jsonl",
    "mrag_dir": "data/extracted/MRAG-20260715T174043Z-1/MRAG",
    "limit": 150,
    "qa_ids": null
  },
  "retrievers": [
    {
      "name": "bm25",
      "kind": "bm25",
      "top_k": 6,
      "options": {},
      "context_modes": ["injected"],
      "interaction": "query_driven"
    },
    {
      "name": "graphrag_local",
      "kind": "external_command",
      "top_k": 6,
      "options": {
        "command": [
          ".venv/bin/python",
          "scripts/query_graphrag_index.py",
          "--api-key-env",
          "LOCAL_OPENAI_API_KEY",
          "--base-url",
          "http://127.0.0.1:11434/v1",
          "--allow-missing-api-key",
          "--reasoning-effort",
          "none",
          "--llm-max-tokens",
          "2048",
          "--query-llm-model",
          "qwen2.5:3b",
          "--query-embedding-model",
          "nomic-embed-text",
          "query",
          "--context-only",
          "--method",
          "local",
          "--top-k",
          "{top_k}",
          "--json",
          "--question",
          "{question}"
        ],
        "check_command": [
          ".venv/bin/python",
          "scripts/query_graphrag_index.py",
          "--api-key-env",
          "LOCAL_OPENAI_API_KEY",
          "--base-url",
          "http://127.0.0.1:11434/v1",
          "--allow-missing-api-key",
          "--reasoning-effort",
          "none",
          "--llm-max-tokens",
          "2048",
          "check"
        ],
        "timeout_s": 600
      },
      "context_modes": ["injected"],
      "interaction": "query_driven"
    },
    {
      "name": "paperqa2_chunks",
      "kind": "external_command",
      "top_k": 6,
      "options": {
        "command": [
          ".venv/bin/python",
          "scripts/query_paperqa_index.py",
          "--api-key-env",
          "LOCAL_OPENAI_API_KEY",
          "--base-url",
          "http://127.0.0.1:11434/v1",
          "--allow-missing-api-key",
          "query",
          "--top-k",
          "{top_k}",
          "--question",
          "{question}",
          "--embedding",
          "nomic-embed-text",
          "--llm",
          "qwen2.5:3b",
          "--summary-llm",
          "qwen2.5:3b"
        ],
        "check_command": [
          ".venv/bin/python",
          "scripts/query_paperqa_index.py",
          "--api-key-env",
          "LOCAL_OPENAI_API_KEY",
          "--base-url",
          "http://127.0.0.1:11434/v1",
          "--allow-missing-api-key",
          "check",
          "--embedding",
          "nomic-embed-text"
        ],
        "timeout_s": 600
      },
      "context_modes": ["injected"],
      "interaction": "query_driven"
    }
  ],
  "context_modes": ["injected"],
  "models": [
    {
      "provider": "dry_run",
      "model": "dry-run",
      "options": {}
    }
  ],
  "grader": {
    "provider": "heuristic",
    "model": "heuristic",
    "options": {}
  },
  "rag_backend": {
    "provider": "local_openai",
    "api_key_env": "LOCAL_OPENAI_API_KEY",
    "base_url": "http://127.0.0.1:11434/v1",
    "allow_missing_api_key": true,
    "chat_model": "qwen2.5:3b",
    "embedding_model": "nomic-embed-text",
    "embedding_dim": 768,
    "vision_model": "qwen2.5vl:3b",
    "reasoning_effort": "none"
  },
  "retrieval_snapshot": "data/working/mutcd150-comparison/retrieval_snapshot.jsonl",
  "output_dir": "runs",
  "max_evidence_chars": 9600,
  "dry_run": false
}
