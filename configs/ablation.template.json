{
  "name": "mutcd-ablation-template",
  "dataset": {
    "qa_path": "data/extracted/MRAG-20260708T114057Z-3/MRAG/eval/gold_qa.jsonl",
    "mrag_dir": "data/extracted/MRAG-20260708T114057Z-3/MRAG"
  },
  "retrievers": [
    {"name": "bm25", "kind": "bm25", "top_k": 6},
    {"name": "hash_vector", "kind": "hash_vector", "top_k": 6, "options": {"dims": 2048}},
    {"name": "qdrant_hash_vector", "kind": "qdrant_hash_vector", "top_k": 6, "options": {"dims": 512, "path": "data/working/qdrant_hash_vector"}},
    {"name": "qdrant_hash_vector_command", "kind": "external_command", "top_k": 6, "options": {"command": [".venv/bin/python", "scripts/query_vector_db.py", "search", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_vector_db.py", "check"], "timeout_s": 120}},
    {"name": "dpr_dense", "kind": "external_command", "top_k": 6, "options": {"command": [".venv/bin/python", "scripts/query_dpr_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_dpr_index.py", "check"], "timeout_s": 600}},
    {"name": "canonical_rag_dpr", "kind": "external_command", "top_k": 6, "options": {"command": [".venv/bin/python", "scripts/query_dpr_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_dpr_index.py", "check"], "timeout_s": 600}},
    {"name": "bm25_graph", "kind": "bm25_graph", "top_k": 8},
    {"name": "self_rag_no_retrieval", "kind": "self_rag_policy", "top_k": 0, "options": {"mode": "no_retrieval", "base_kind": "bm25_graph"}},
    {"name": "self_rag_always_bm25_graph", "kind": "self_rag_policy", "top_k": 8, "options": {"mode": "always_retrieve", "base_kind": "bm25_graph"}},
    {"name": "self_rag_adaptive_bm25_graph", "kind": "self_rag_policy", "top_k": 8, "options": {"mode": "adaptive_retrieval", "threshold": 0.2, "base_kind": "bm25_graph"}},
    {"name": "crag_bm25_corrective", "kind": "crag_policy", "top_k": 8, "options": {"primary_kind": "bm25", "fallback_kind": "bm25_graph", "accept_threshold": 0.45, "reject_threshold": 0.18}},
    {"name": "sam_rag_adaptive_multimodal", "kind": "sam_rag", "top_k": 8, "options": {"candidate_k": 18, "batch_size": 6, "relevance_threshold": 0.2}},
    {"name": "kg2rag_graph_guided", "kind": "kg2rag", "top_k": 8, "options": {"seed_k": 4, "graph_hops": 2}},
    {"name": "m3kg_rag_paper_spec", "kind": "m3kg_rag", "top_k": 8, "options": {"seed_k": 4, "graph_hops": 2, "presence_threshold": 0.2}},
    {"name": "okh_rag_paper_spec", "kind": "okh_rag", "top_k": 8, "options": {"seed_k": 4, "graph_hops": 2}},
    {"name": "oracle_gold_refs", "kind": "oracle", "top_k": 12},
    {"name": "gems_dense_text", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "dense", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "dense"], "timeout_s": 600}},
    {"name": "gems_hybrid_text", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "hybrid", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "hybrid"], "timeout_s": 600}},
    {"name": "gems_multimodal_no_graph", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "multimodal", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "multimodal"], "timeout_s": 600}},
    {"name": "gems_full", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "full", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "full"], "timeout_s": 600}},
    {"name": "gems_no_graph", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "no_graph", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "no_graph"], "timeout_s": 600}},
    {"name": "gems_no_visual", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "no_visual", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "no_visual"], "timeout_s": 600}},
    {"name": "gems_no_rule", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "no_rule", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "no_rule"], "timeout_s": 600}},
    {"name": "gems_no_hierarchy", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "no_hierarchy", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "no_hierarchy"], "timeout_s": 600}},
    {"name": "graphrag_local", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_graphrag_index.py", "query", "--method", "local", "--top-k", "{top_k}", "--json", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_graphrag_index.py", "check"], "timeout_s": 600}},
    {"name": "lightrag_hybrid_context", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_lightrag_index.py", "query", "--mode", "hybrid", "--top-k", "{top_k}", "--chunk-top-k", "{top_k}", "--only-need-context", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_lightrag_index.py", "check"], "timeout_s": 300}},
    {"name": "hipporag", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_hipporag_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_hipporag_index.py", "check"], "timeout_s": 600}},
    {"name": "raganything_hybrid", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_raganything_index.py", "query", "--mode", "hybrid", "--top-k", "{top_k}", "--chunk-top-k", "{top_k}", "--only-need-context", "--json", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_raganything_index.py", "check"], "timeout_s": 300}},
    {"name": "visrag_pages", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_visrag_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_visrag_index.py", "check"], "timeout_s": 600}},
    {"name": "paperqa2_chunks", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_paperqa_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_paperqa_index.py", "check"], "timeout_s": 600}}
  ],
  "context_modes": ["injected", "tool_explore", "tool_search", "tool_native"],
  "models": [
    {
      "provider": "openai",
      "model": "gpt-5.6-terra",
      "options": {"api": "responses", "max_tokens": 900, "reasoning_effort": "low", "temperature": null}
    },
    {
      "provider": "anthropic",
      "model": "claude-haiku-4-5",
      "options": {"max_tokens": 900}
    },
    {
      "provider": "xai",
      "model": "grok-4.5",
      "options": {"max_tokens": 900}
    },
    {
      "provider": "qwen",
      "model": "qwen3.6-flash",
      "options": {"max_tokens": 900}
    },
    {
      "provider": "local_openai",
      "model": "local-small",
      "options": {"base_url": "http://localhost:8000/v1", "max_tokens": 900}
    }
  ],
  "grader": {
    "provider": "openai",
    "model": "gpt-5.6-sol",
    "options": {"api": "responses", "max_output_tokens": 1600, "reasoning_effort": "xhigh", "temperature": null}
  },
  "output_dir": "runs",
  "max_evidence_chars": 7000
}
