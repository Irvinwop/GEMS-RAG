{
  "name": "mutcd-ablation-template",
  "dataset": {
    "qa_path": "data/extracted/MRAG-20260708T114057Z-3/MRAG/eval/gold_qa.jsonl",
    "mrag_dir": "data/extracted/MRAG-20260708T114057Z-3/MRAG"
  },
  "retrievers": [
    {"name": "bm25", "kind": "bm25", "top_k": 6},
    {"name": "hash_vector", "kind": "hash_vector", "top_k": 6, "options": {"dims": 2048}},
    {"name": "qdrant_hash_vector", "kind": "qdrant_hash_vector", "top_k": 6, "options": {"dims": 512, "path": "data/working/qdrant_hash_vector"}},
    {"name": "qdrant_hash_vector_command", "kind": "external_command", "top_k": 6, "options": {"command": [".venv/bin/python", "scripts/query_vector_db.py", "search", "--top-k", "6", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_vector_db.py", "check"], "timeout_s": 120}},
    {"name": "bm25_graph", "kind": "bm25_graph", "top_k": 8},
    {"name": "self_rag_no_retrieval", "kind": "self_rag_policy", "top_k": 0, "options": {"mode": "no_retrieval", "base_kind": "bm25_graph"}},
    {"name": "self_rag_always_bm25_graph", "kind": "self_rag_policy", "top_k": 8, "options": {"mode": "always_retrieve", "base_kind": "bm25_graph"}},
    {"name": "self_rag_adaptive_bm25_graph", "kind": "self_rag_policy", "top_k": 8, "options": {"mode": "adaptive_retrieval", "threshold": 0.2, "base_kind": "bm25_graph"}},
    {"name": "crag_bm25_corrective", "kind": "crag_policy", "top_k": 8, "options": {"primary_kind": "bm25", "fallback_kind": "bm25_graph", "accept_threshold": 0.45, "reject_threshold": 0.18}},
    {"name": "oracle_gold_refs", "kind": "oracle", "top_k": 12},
    {"name": "mrag_reference_text", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--top-k", "6", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check"], "timeout_s": 600}},
    {"name": "graphrag_local", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_graphrag_index.py", "query", "--method", "local", "--json", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_graphrag_index.py", "check"], "timeout_s": 600}},
    {"name": "lightrag_hybrid_context", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_lightrag_index.py", "query", "--mode", "hybrid", "--only-need-context", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_lightrag_index.py", "check"], "timeout_s": 300}},
    {"name": "hipporag", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_hipporag_index.py", "query", "--top-k", "6", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_hipporag_index.py", "check"], "timeout_s": 600}},
    {"name": "raganything_hybrid", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_raganything_index.py", "query", "--mode", "hybrid", "--json", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_raganything_index.py", "check"], "timeout_s": 300}},
    {"name": "visrag_pages", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_visrag_index.py", "query", "--top-k", "6", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_visrag_index.py", "check"], "timeout_s": 600}},
    {"name": "paperqa2_chunks", "kind": "external_command", "options": {"command": [".venv/bin/python", "scripts/query_paperqa_index.py", "query", "--question", "{question}"], "check_command": [".venv/bin/python", "scripts/query_paperqa_index.py", "check"], "timeout_s": 600}}
  ],
  "context_modes": ["injected", "tool_explore", "tool_search"],
  "models": [
    {
      "provider": "openai",
      "model": "gpt-5.4-mini",
      "options": {"api": "responses", "max_tokens": 900, "reasoning_effort": "low", "temperature": null}
    },
    {
      "provider": "anthropic",
      "model": "claude-haiku-4-5",
      "options": {"max_tokens": 900}
    },
    {
      "provider": "xai",
      "model": "grok-4.5",
      "options": {"max_tokens": 900}
    },
    {
      "provider": "qwen",
      "model": "qwen3.6-flash",
      "options": {"max_tokens": 900}
    },
    {
      "provider": "local_openai",
      "model": "local-small",
      "options": {"base_url": "http://localhost:8000/v1", "max_tokens": 900}
    }
  ],
  "grader": {
    "provider": "openai",
    "model": "gpt-5.5",
    "options": {"api": "responses", "max_output_tokens": 1600, "reasoning_effort": "xhigh", "temperature": null}
  },
  "output_dir": "runs",
  "max_evidence_chars": 7000
}
