{
  "defaults": {
    "top_k": 6
  },
  "retrievers": [
    {
      "name": "bm25",
      "kind": "bm25",
      "family": "local",
      "modes": ["lexical"],
      "tags": ["local", "text", "baseline"]
    },
    {
      "name": "qdrant_hash_vector",
      "kind": "qdrant_hash_vector",
      "family": "local",
      "modes": ["vector"],
      "tags": ["local", "vector", "tool"],
      "options": {
        "dims": 512,
        "path": "data/working/qdrant_hash_vector"
      }
    },
    {
      "name": "qdrant_hash_vector_command",
      "kind": "external_command",
      "family": "local_vector_db",
      "modes": ["vector", "command"],
      "tags": ["local", "vector", "tool", "command"],
      "options": {
        "command": [".venv/bin/python", "scripts/query_vector_db.py", "search", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_vector_db.py", "check"],
        "timeout_s": 120
      }
    },
    {
      "name": "dpr_dense",
      "kind": "external_command",
      "family": "dpr",
      "modes": ["dense"],
      "tags": ["external", "text", "dense", "official-checkpoint", "manuscript-system"],
      "options": {
        "command": [".venv/bin/python", "scripts/query_dpr_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_dpr_index.py", "check"],
        "timeout_s": 600
      }
    },
    {
      "name": "canonical_rag_dpr",
      "kind": "external_command",
      "family": "canonical_rag",
      "modes": ["sequence"],
      "tags": ["external", "text", "dense", "official-checkpoint", "manuscript-system"],
      "options": {
        "command": [".venv/bin/python", "scripts/query_dpr_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_dpr_index.py", "check"],
        "timeout_s": 600
      },
      "notes": "Canonical RAG retrieval with DPR; generation is normalized through the selected harness model."
    },
    {
      "name": "gfm_rag",
      "kind": "external_command",
      "family": "gfm_rag",
      "modes": ["graph_foundation_model"],
      "tags": ["external", "graph", "pretrained", "official-runtime", "manuscript-system"],
      "options": {
        "command": [".venv/bin/python", "scripts/query_gfmrag_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_gfmrag_index.py", "check"],
        "timeout_s": 600
      }
    },
    {
      "name": "bm25_graph",
      "kind": "bm25_graph",
      "family": "local",
      "modes": ["graph_expand"],
      "tags": ["local", "graph", "text"],
      "options": {
        "graph_weight": 0.35,
        "graph_neighbors": 8
      }
    },
    {
      "name": "oracle_gold_refs",
      "kind": "oracle",
      "family": "oracle",
      "modes": ["gold_refs"],
      "tags": ["local", "upper-bound"]
    },
    {
      "name": "self_rag_no_retrieval",
      "kind": "self_rag_policy",
      "family": "self_rag_policy",
      "modes": ["no_retrieval"],
      "tags": ["local", "policy"],
      "options": {
        "mode": "no_retrieval",
        "base_retriever": {"name": "bm25_graph", "kind": "bm25_graph", "top_k": 6}
      }
    },
    {
      "name": "self_rag_always_retrieve",
      "kind": "self_rag_policy",
      "family": "self_rag_policy",
      "modes": ["always_retrieve"],
      "tags": ["local", "policy"],
      "options": {
        "mode": "always_retrieve",
        "base_retriever": {"name": "bm25_graph", "kind": "bm25_graph", "top_k": 6}
      }
    },
    {
      "name": "self_rag_adaptive_bm25_graph",
      "kind": "self_rag_policy",
      "family": "self_rag_policy",
      "modes": ["adaptive_retrieval"],
      "tags": ["local", "policy"],
      "options": {
        "mode": "adaptive_retrieval",
        "base_retriever": {"name": "bm25_graph", "kind": "bm25_graph", "top_k": 6},
        "retrieval_keywords": ["section", "standard", "guidance", "option", "support", "figure", "table", "shall", "should", "may"]
      }
    },
    {
      "name": "crag_bm25_corrective",
      "kind": "crag_policy",
      "family": "crag_policy",
      "modes": ["corrective"],
      "tags": ["local", "policy"],
      "options": {
        "primary_retriever": {"name": "bm25", "kind": "bm25", "top_k": 6},
        "fallback_retriever": {"name": "bm25_graph", "kind": "bm25_graph", "top_k": 6},
        "confidence_threshold": 0.28,
        "fallback_threshold": 0.12
      }
    },
    {
      "name": "sam_rag_adaptive_multimodal",
      "kind": "sam_rag",
      "family": "sam_rag",
      "modes": ["adaptive_multimodal"],
      "tags": ["local", "multimodal", "adaptive", "manuscript-system", "paper-adaptation"],
      "options": {
        "candidate_k": 18,
        "batch_size": 6,
        "relevance_threshold": 0.2
      },
      "notes": "Retrieval-side adaptation of the official SAM-RAG flow; answer support/usefulness are measured by harness grading."
    },
    {
      "name": "lpkg_planned_retrieval",
      "kind": "lpkg",
      "family": "lpkg",
      "modes": ["planned_iterative_retrieval"],
      "tags": ["local", "planned", "iterative", "manuscript-system", "official-plan-format"],
      "options": {
        "plans_path": "data/working/lpkg/generated_plans.jsonl",
        "per_step_k": 5,
        "base_kind": "hash_vector",
        "base_options": {"dims": 2048}
      },
      "notes": "Consumes normalized generated_predictions.jsonl from the official LPKG planner, executes each Sub_Question_n against the shared corpus, and records dependency substitutions."
    },
    {
      "name": "kg2rag_graph_guided",
      "kind": "kg2rag",
      "family": "kg2rag",
      "modes": ["seed_expand_organize"],
      "tags": ["local", "graph", "manuscript-system", "official-algorithm-adaptation"],
      "options": {
        "seed_k": 4,
        "graph_hops": 2
      }
    },
    {
      "name": "m3kg_rag_paper_spec",
      "kind": "m3kg_rag",
      "family": "m3kg_rag",
      "modes": ["modality_graph_grasp"],
      "tags": ["local", "graph", "multimodal", "manuscript-system", "paper-spec"],
      "options": {
        "seed_k": 4,
        "graph_hops": 2,
        "presence_threshold": 0.2
      },
      "notes": "Image/text MUTCD paper-spec adaptation; the cited audio-visual paper has no public code and this corpus has no audio."
    },
    {
      "name": "okh_rag_paper_spec",
      "kind": "okh_rag",
      "family": "okh_rag",
      "modes": ["ordered_trajectory"],
      "tags": ["local", "graph", "ordered", "manuscript-system", "paper-spec"],
      "options": {
        "seed_k": 4,
        "graph_hops": 2
      },
      "notes": "Uses MUTCD sections as higher-order hyperedges and document order as observable precedence; no author code/checkpoint is public."
    },
    {
      "name": "mrag_reference_text",
      "kind": "external_command",
      "family": "mrag_reference",
      "modes": ["no_visual"],
      "tags": ["external", "reference", "text", "compatibility"],
      "options": {
        "command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "no_visual", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "no_visual"],
        "timeout_s": 600
      }
    },
