{
  "name": "smoke-local",
  "dataset": {
    "qa_path": "data/extracted/MRAG-20260708T114057Z-3/MRAG/eval/gold_qa.jsonl",
    "mrag_dir": "data/extracted/MRAG-20260708T114057Z-3/MRAG",
    "limit": 3
  },
  "retrievers": [
    {
      "name": "bm25",
      "kind": "bm25",
      "top_k": 6
    },
    {
      "name": "hash_vector",
      "kind": "hash_vector",
      "top_k": 6,
      "options": {
        "dims": 2048
      }
    },
    {
      "name": "qdrant_hash_vector",
      "kind": "qdrant_hash_vector",
      "top_k": 6,
      "options": {
        "dims": 512,
        "path": "data/working/qdrant_hash_vector"
      }
    },
    {
      "name": "bm25_graph",
      "kind": "bm25_graph",
      "top_k": 8
    },
    {
      "name": "self_rag_adaptive_bm25_graph",
      "kind": "self_rag_policy",
      "top_k": 8,
      "options": {
        "mode": "adaptive_retrieval",
        "threshold": 0.2,
        "base_kind": "bm25_graph"
      }
    },
    {
      "name": "crag_bm25_corrective",
      "kind": "crag_policy",
      "top_k": 8,
      "options": {
        "primary_kind": "bm25",
        "fallback_kind": "bm25_graph",
        "accept_threshold": 0.45,
        "reject_threshold": 0.18
      }
    },
    {
      "name": "oracle_gold_refs",
      "kind": "oracle",
      "top_k": 12
    }
  ],
  "context_modes": ["injected", "tool_explore", "tool_search", "tool_native"],
  "models": [
    {
      "provider": "dry_run",
      "model": "dry-run"
    }
  ],
  "grader": {
    "provider": "heuristic",
    "model": "heuristic"
  },
  "output_dir": "runs",
  "max_evidence_chars": 5000
}
