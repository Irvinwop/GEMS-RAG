{
  "name": "external-rag-smoke",
  "dataset": {
    "qa_path": "data/extracted/MRAG-20260715T174043Z-1/MRAG/eval/gold_qa.jsonl",
    "mrag_dir": "data/extracted/MRAG-20260715T174043Z-1/MRAG",
    "limit": 1
  },
  "retrievers": [
    {
      "name": "gems_dense_text",
      "kind": "external_command",
      "options": {
        "command": [".venv/bin/python", "scripts/query_mrag_reference.py", "retrieve", "--mode", "dense", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_mrag_reference.py", "check", "--mode", "dense"],
        "timeout_s": 30
      }
    },
    {
      "name": "graphrag_local",
      "kind": "external_command",
      "options": {
        "command": [".venv/bin/python", "scripts/query_graphrag_index.py", "query", "--method", "local", "--top-k", "{top_k}", "--json", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_graphrag_index.py", "check"],
        "timeout_s": 30
      }
    },
    {
      "name": "lightrag_hybrid_context",
      "kind": "external_command",
      "options": {
        "command": [".venv/bin/python", "scripts/query_lightrag_index.py", "query", "--mode", "hybrid", "--top-k", "{top_k}", "--chunk-top-k", "{top_k}", "--only-need-context", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_lightrag_index.py", "check"],
        "timeout_s": 30
      }
    },
    {
      "name": "hipporag",
      "kind": "external_command",
      "options": {
        "command": [".venv/bin/python", "scripts/query_hipporag_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_hipporag_index.py", "check"],
        "timeout_s": 30
      }
    },
    {
      "name": "raganything_hybrid",
      "kind": "external_command",
      "options": {
        "command": [".venv/bin/python", "scripts/query_raganything_index.py", "query", "--mode", "hybrid", "--top-k", "{top_k}", "--chunk-top-k", "{top_k}", "--only-need-context", "--json", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_raganything_index.py", "check"],
        "timeout_s": 30
      }
    },
    {
      "name": "visrag_pages",
      "kind": "external_command",
      "options": {
        "command": [".venv/bin/python", "scripts/query_visrag_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_visrag_index.py", "check"],
        "timeout_s": 30
      }
    },
    {
      "name": "paperqa2_chunks",
      "kind": "external_command",
      "options": {
        "command": [".venv/bin/python", "scripts/query_paperqa_index.py", "query", "--top-k", "{top_k}", "--question", "{question}"],
        "check_command": [".venv/bin/python", "scripts/query_paperqa_index.py", "check"],
        "timeout_s": 30
      }
    }
  ],
  "context_modes": ["injected", "tool_explore", "tool_search", "tool_native"],
  "models": [
    {
      "provider": "dry_run",
      "model": "dry-run"
    }
  ],
  "grader": {
    "provider": "heuristic",
    "model": "heuristic"
  },
  "output_dir": "runs",
  "max_evidence_chars": 7000
}
